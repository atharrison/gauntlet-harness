# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Ticket tracker ────────────────────────────────────────────────────────────
TICKET_PROVIDER=linear
LINEAR_API_KEY=

# ── Memory ────────────────────────────────────────────────────────────────────
# "supabase" for web/team-shared, "sqlite" for CLI/local
MEMORY_PROVIDER=supabase

# Supabase — used for SupabaseMemoryStore + auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Delivery ──────────────────────────────────────────────────────────────────
# "web" | "cli"
DELIVERY=web

# ── Guardrails ────────────────────────────────────────────────────────────────
# Set true in dev to prevent writing to GitHub PR
DRY_RUN=false
MAX_TURNS=20
MAX_TOKENS=200000
TIMEOUT_MS=300000
# Max external context lookups (codebase search, past reviews) per run
SCOPE_BUDGET=10
# PR size gate: warn above these thresholds
PR_MAX_FILES=50
PR_MAX_LINES=3000

# ── Observability ─────────────────────────────────────────────────────────────
# Leave blank to emit OTel spans to stdout (dev mode)
# Set to your OTLP endpoint for Langfuse, SigNoz, Datadog, etc.
OTEL_EXPORTER_OTLP_ENDPOINT=
