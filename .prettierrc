{
  "semi": false,
  "singleQuote": true,
  "arrowParens": "avoid",
  "trailingComma": "es5",
  "plugins": ["prettier-plugin-sql"],
  "overrides": [
    {
      "files": ["*.sql"],
      "options": {
        "language": "postgresql",
        "keywordCase": "lower",
        "dataTypeCase": "lower",
        "functionCase": "lower",
        "identifierCase": "preserve",
        "indentStyle": "standard",
        "logicalOperatorNewline": "before",
        "expressionWidth": 50,
        "linesBetweenQueries": 1,
        "denseOperators": false,
        "newlineBeforeSemicolon": false
      }
    }
  ]
}
